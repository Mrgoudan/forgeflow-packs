# machine-local pack config: the real project.yaml is tracked, others ignored
packs/*/project.yaml
!packs/bsc/project.yaml

# real secrets — NEVER commit
secrets.env

# shared runtime: db, worktrees, archived outputs
run/

# python
__pycache__/
*.pyc

# method-asset vault (own git repo, nested) — not tracked by the pack repo
/vault/
