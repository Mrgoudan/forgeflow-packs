# BSC review pack — copy to project.yaml, fill machine-local values.
# Reuses the generic review pack's blocks; adds BSC context + GLM agents.
name: bsc

paths:
  repo:       /home/ziruichen/bsd/llvm-project-dup   # the reviewed repo (PR heads fetched here)
  code_notes: /home/ziruichen/bsd/forgeflow-vault/bsc/code_notes

tools:
  git: { path: git, version_cmd: ["--version"] }

workflows: [workflows]
# reuse the generic review blocks by path, then add the BSC providers
blocks:
  - ../review/blocks/reviewblocks.py
  - ../review/blocks/forge.py
  - ../review/blocks/providers.py
  - blocks/bsc.py

prompts:
  review: prompts/review.md
  refute: prompts/refute.md
schemas:
  review_findings:  ../review/schemas/review_findings.yaml
  refute_decisions: ../review/schemas/refute_decisions.yaml

agents:
  # GLM backing the AGENTIC claude CLI (so bsc-* skills + worktree work).
  # Point the CLI at GLM's Anthropic-compatible endpoint by exporting these
  # in the daemon environment (systemd EnvironmentFile, 0600):
  #   ANTHROPIC_BASE_URL=https://<glm-anthropic-endpoint>
  #   ANTHROPIC_AUTH_TOKEN=<glm-key>
  # env_keys forwards them into the agent process; they never touch pack files.
  review: { backend: claude-cli, model: glm-4.6,
            env_keys: [ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN] }
  refute: { backend: claude-cli, model: glm-4.6,
            env_keys: [ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN] }

params:
  # The user manual is a file INSIDE the reviewed repo — ground truth.
  manual_path: clang/docs/BSC/BiShengCLanguageUserManual.md

  # Manual-wins precedence: the manual blob the bsc-* skills were validated
  # against. While the manual at the PR head == this, skills are trusted;
  # once it differs, the manual is flagged CHANGED and overrides the skills.
  # Get it with:  git -C <repo> rev-parse HEAD:clang/docs/BSC/BiShengCLanguageUserManual.md
  # Bump after re-validating skills against a new manual.
  manual_pinned_sha: 637bd165d0f4cfab13fbc021dc08ad2b199aad58

  # A PR touching any of these but NOT the manual is flagged (manual must be
  # updated before review — it is ground truth).
  semantics_prefixes:
    - clang/lib/Sema/BSC
    - clang/lib/Analysis/BSC
    - clang/lib/CodeGen/BSC
    - clang/lib/Parse

  # touched-path-prefix -> code note file (under paths.code_notes)
  subsystem_map:
    clang/lib/Sema/BSC: BSCOwnership.md
    clang/lib/Analysis/BSC: BSCBorrowChecker.md

  # forge (gitee/gitcode v5 shape) — same as the generic review pack
  prs_url:     "https://your-forge/api/v5/repos/OWNER/REPO/pulls?state=open"
  comment_url: "https://your-forge/api/v5/repos/OWNER/REPO/pulls/{payload.request.pr}/comments"
  forge_auth:  { token_ref: MAIN, style: query, name: access_token }
  deny_patterns: ["BEGIN [A-Z]+ PRIVATE KEY"]
  min_severity: medium
