# forgeflow secrets — copy to config/secrets.env and `chmod 600`, then fill
# the two REPLACE_* values. run-bsc.sh sources this file:
#   - ANTHROPIC_* go into the daemon env, forwarded to the agent by env_keys
#     (they back the claude CLI with GLM, so the bsc-* skills load);
#   - FORGE_TOKEN_* are read by load_secrets() (never argv, never logged).
# The real config/secrets.env is gitignored — never committed.

# GLM behind the agentic claude CLI:
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_AUTH_TOKEN=REPLACE_WITH_YOUR_GLM_KEY

# gitcode API token (matches forge_auth.token_ref: MAIN):
FORGE_TOKEN_MAIN=REPLACE_WITH_YOUR_GITCODE_TOKEN

# Uncomment only when ready to POST to real PRs:
# FORGE_WRITE=1
