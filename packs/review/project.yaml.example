# Review pack — copy to project.yaml and fill machine-local values.
# project.yaml is gitignored; this example is the documentation.
name: review

paths:
  repo: /absolute/path/to/local/clone      # must exist; PR heads fetched into it

tools:
  git: { path: git, version_cmd: ["--version"] }

workflows: [workflows]
blocks:    [blocks/reviewblocks.py, blocks/forge.py, blocks/providers.py]

prompts:
  review: prompts/review.md
schemas:
  review_findings: schemas/review_findings.yaml

agents:
  # which model reviews, on THIS machine; omit model to use the CLI default
  review: { backend: claude-cli }

# Forge access is pure config: URL templates + a token ref. The token
# lives in the secrets file as FORGE_TOKEN_<REF> (chmod 600) — never here.
# Runtime placeholders ({payload.*}) resolve when the block runs.
# gitee/gitcode v5 style shown; adjust paths for your forge's REST shape.
params:
  prs_url: "https://your-forge/api/v5/repos/OWNER/REPO/pulls?state=open"
  comment_url: "https://your-forge/api/v5/repos/OWNER/REPO/pulls/{payload.request.pr}/comments"
  forge_auth: { token_ref: MAIN, style: query, name: access_token }
  deny_patterns: ["BEGIN [A-Z]+ PRIVATE KEY"]   # egress leak scan

# Live sends require FORGE_WRITE=1 in the daemon's environment; without
# it every comment is archived (egress row + body on disk), never posted.
