# Review pack — copy to project.yaml and fill machine-local values.
# project.yaml is gitignored; this example is the documentation.
name: review

paths:
  repo: /absolute/path/to/the/repo/you/review    # must exist at startup

tools:
  git: { path: git, version_cmd: ["--version"] }

workflows: [workflows]
blocks:    [blocks/reviewblocks.py]

prompts:
  review: prompts/review.md
schemas:
  review_findings: schemas/review_findings.yaml

agents:
  # which model reviews, on THIS machine; omit model to use the CLI default
  review: { backend: claude-cli }
