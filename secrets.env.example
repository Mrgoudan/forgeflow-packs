# forgeflow BSC secrets — copy to ~/.config/forgeflow/secrets.env and
# `chmod 600` it (the engine refuses to read anything looser). Fill in the
# values below. run-bsc.sh sources this file, so:
#   - ANTHROPIC_* land in the daemon environment and are forwarded to the
#     agent process by the pack's `env_keys` (they back the claude CLI
#     with GLM, which is what lets the bsc-* skills load);
#   - FORGE_TOKEN_* are read by the engine's load_secrets() from this file
#     (never from argv, never from pack files, never logged).

# ---- GLM as the model behind the agentic claude CLI --------------------
# GLM exposes an Anthropic-compatible endpoint; point the CLI at it.
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_AUTH_TOKEN=PUT-YOUR-GLM-API-KEY-HERE

# ---- forge (gitee/gitcode) API token -----------------------------------
# Matches forge_auth.token_ref in project.yaml (here: MAIN).
FORGE_TOKEN_MAIN=PUT-YOUR-FORGE-TOKEN-HERE

# ---- egress gate -------------------------------------------------------
# Leave commented for a dry run (comments archived, never posted). Set to 1
# only when you are ready for the reviewer to post to real PRs.
# FORGE_WRITE=1
