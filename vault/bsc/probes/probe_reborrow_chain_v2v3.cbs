// v2 + v3 — NLL allows reborrow chain when last-uses ladder bottom-up.
_Safe void use(int *_Borrow p) { (void)p; }

_Safe int v2(void) {
    int x = 1;
    int *_Borrow b1 = &_Mut x;
    int *_Borrow b2 = &_Mut *b1;
    use(b2);
    use(b1);
    return 0;
}
_Safe int v3(void) {
    int x = 1;
    int *_Borrow b1 = &_Mut x;
    int *_Borrow b2 = &_Mut *b1;
    int *_Borrow b3 = &_Mut *b2;
    use(b3);
    use(b2);
    use(b1);
    return 0;
}
